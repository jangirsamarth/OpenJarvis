{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Permissions for the principal window",
  "windows": ["main"],
  "permissions": [
    "core:app:default",
    "core:event:default",
    "core:window:default",
    "core:image:default",
    "core:menu:default",
    "core:path:default",
    "core:resources:default",
    "core:tray:default",
    "core:webview:default",
    "shell:default",
    "shell:allow-execute",
    "shell:allow-spawn",
    "process:default",
    "notification:default",
    "global-shortcut:default",
    "autostart:default",
    "updater:default"
  ]
}
